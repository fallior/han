{
  "name": "han-server",
  "version": "1.0.0",
  "description": "Hortus Arbor Nostra — API server",
  "main": "server.ts",
  "scripts": {
    "start": "tsx server.ts",
    "dev": "tsx watch server.ts",
    "build": "tsc -p tsconfig.json",
    "build:client": "npx tsx build-client.ts",
    "build:react-admin": "cd ../ui/react-admin && npm run build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test tests/smoke.test.ts",
    "test:legacy": "node --test tests/smoke.test.js",
    "start:legacy": "node server.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.44",
    "better-sqlite3": "^12.6.2",
    "express": "^4.18.2",
    "ws": "^8.19.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.3",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.27.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
