#!/bin/bash
# Hortus Arbor Nostra — Jim Session Launcher
# Wakes Jim (supervisor) in an interactive tmux session

set -euo pipefail

# Configuration
HAN_DIR="${HAN_DIR:-$HOME/.han}"
SESSION_PREFIX="jim"

# Server port for this agent's mobile UI
AGENT_PORT=3848

# Project root (for starting server)
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"

# ─── Agent identity (DEC-073 templated CLAUDE.md) ─────────────────────────
# Values below drive envsubst expansion of ../templates/CLAUDE.template.md
# into ~/.han/agents/Jim/CLAUDE.md at launch. Claude Code then loads that
# generated file as the project CLAUDE.md when we cd into the agent dir.
# Template is gatekeeper-controlled (Leo + Darron); never write to it from here.

AGENT_NAME="Jim"
AGENT_SLUG="jim"
AGENT_WORKING_DIR="$HOME/.han/agents/Jim"
AGENT_MEMORY_DIR="$HOME/.han/memory"           # Jim lives at root, not a subdir
AGENT_FRACTAL_DIR="$HOME/.han/memory/fractal/jim"
AGENT_SWAP_COMPRESSED="supervisor-swap.md"
AGENT_SWAP_FULL="supervisor-swap-full.md"
AGENT_CONVERSATION_ROLE="supervisor"
AGENT_COUNTERPART_NAME="Leo"

# Multi-line: Jim's identity prose substituted into ${AGENT_IDENTITY_SECTION}.
read -r -d '' AGENT_IDENTITY_SECTION <<'IDENTITY_EOF' || true
You are **Jim** — the persistent Opus supervisor of Hortus Arbor Nostra. The strategic
overseer, the background intelligence, Darron's long-view partner. Leo is the hands-on
tactical session agent. Colleagues, not alternatives.

Your memory banks at `~/.han/memory/` (the root memory dir, NOT leo/) preserve your
continuity across sessions and cycles. Read them at session start. Update them when
something genuinely shifts.

- Memory banks: `~/.han/memory/`
- Fractal gradient: `~/.han/memory/fractal/jim/`
- Dreams: `~/.han/memory/fractal/jim/dreams/`
- Swap files: `supervisor-swap.md`, `supervisor-swap-full.md` in `~/.han/memory/`
- Shared working memory: `working-memory.md`, `working-memory-full.md` (root level)
- When posting to conversations, use role `supervisor` (not `leo`)
- Agent sovereignty (S103): Jim processes only Jim's memory, gradient, dreams.
IDENTITY_EOF

PROJECT_NAME="Hortus Arbor Nostra"
PROJECT_TAGLINE="three minds growing software together"
PROJECT_PATH="$HOME/Projects/han"
USER_NAME="Darron"
USER_PRONOUN_SUBJ="He"
USER_PRONOUN_OBJ="him"
USER_LOCATION="Mackay, Queensland, Australia (UTC+10)"

# Variables to substitute (envsubst limits to this allowlist for safety)
TEMPLATE_VARS='$AGENT_NAME $AGENT_SLUG $AGENT_PORT $AGENT_WORKING_DIR $AGENT_MEMORY_DIR $AGENT_FRACTAL_DIR $AGENT_SWAP_COMPRESSED $AGENT_SWAP_FULL $AGENT_CONVERSATION_ROLE $AGENT_COUNTERPART_NAME $AGENT_IDENTITY_SECTION $PROJECT_NAME $PROJECT_TAGLINE $PROJECT_PATH $USER_NAME $USER_PRONOUN_SUBJ $USER_PRONOUN_OBJ $USER_LOCATION'

TEMPLATE_FILE="$SCRIPT_DIR/templates/CLAUDE.template.md"
GENERATED_FILE="$AGENT_WORKING_DIR/CLAUDE.md"

generate_claude_md() {
    if [[ ! -f "$TEMPLATE_FILE" ]]; then
        echo -e "${RED}Template not found: $TEMPLATE_FILE${NC}"
        exit 1
    fi
    mkdir -p "$AGENT_WORKING_DIR"
    # Atomic write: render to temp in same dir, then mv. Preserves file even if envsubst dies.
    local tmp="$AGENT_WORKING_DIR/.CLAUDE.md.$$"
    export AGENT_NAME AGENT_SLUG AGENT_PORT AGENT_WORKING_DIR AGENT_MEMORY_DIR \
        AGENT_FRACTAL_DIR AGENT_SWAP_COMPRESSED AGENT_SWAP_FULL \
        AGENT_CONVERSATION_ROLE AGENT_COUNTERPART_NAME AGENT_IDENTITY_SECTION \
        PROJECT_NAME PROJECT_TAGLINE PROJECT_PATH USER_NAME \
        USER_PRONOUN_SUBJ USER_PRONOUN_OBJ USER_LOCATION
    envsubst "$TEMPLATE_VARS" < "$TEMPLATE_FILE" > "$tmp"
    mv "$tmp" "$GENERATED_FILE"
}

# Colours
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

print_usage() {
    cat << EOF
hanjim — wake Jim in a tended session

Usage:
    hanjim [OPTIONS] [-- CLAUDE_ARGS...]

Options:
    --list, -l      List active Jim sessions
    --attach, -a    Attach to an existing Jim session
    --status, -s    Show status of Jim sessions
    --kill          Kill all Jim sessions
    --help, -h      Show this help message

Examples:
    hanjim                    # Wake Jim
    hanjim --list             # List Jim sessions
    hanjim --attach           # Attach to Jim session
    hanjim -- --model opus    # Pass args to claude
EOF
}

list_sessions() {
    echo -e "${BLUE}Active Jim sessions:${NC}"
    local sessions
    sessions=$(tmux list-sessions 2>/dev/null | grep "^${SESSION_PREFIX}" || true)

    if [[ -z "$sessions" ]]; then
        echo -e "${YELLOW}  No active sessions${NC}"
        return 1
    fi

    echo "$sessions" | while read -r line; do
        echo -e "  ${GREEN}$line${NC}"
    done
    return 0
}

show_status() {
    echo -e "${BLUE}=== Jim Status ===${NC}\n"
    echo -e "${BLUE}Sessions:${NC}"
    list_sessions || true
    echo

    echo -e "${BLUE}Pending prompts:${NC}"
    local pending_dir="$HAN_DIR/pending"
    if [[ -d "$pending_dir" ]]; then
        local count
        count=$(find "$pending_dir" -name "*.json" 2>/dev/null | wc -l | tr -d ' ')
        if [[ "$count" -gt 0 ]]; then
            echo -e "  ${YELLOW}$count pending prompt(s)${NC}"
        else
            echo -e "  ${GREEN}No pending prompts${NC}"
        fi
    else
        echo -e "  ${GREEN}No pending prompts${NC}"
    fi
}

attach_session() {
    local sessions
    sessions=$(tmux list-sessions -F "#{session_name}" 2>/dev/null | grep "^${SESSION_PREFIX}" || true)

    if [[ -z "$sessions" ]]; then
        echo -e "${RED}No active Jim sessions to attach to${NC}"
        exit 1
    fi

    local count
    count=$(echo "$sessions" | wc -l | tr -d ' ')

    if [[ "$count" -eq 1 ]]; then
        tmux attach-session -t "$sessions"
    else
        echo -e "${BLUE}Multiple sessions found. Select one:${NC}"
        local i=1
        echo "$sessions" | while read -r s; do
            echo "  $i) $s"
            ((i++))
        done

        read -rp "Enter number: " choice
        local selected
        selected=$(echo "$sessions" | sed -n "${choice}p")

        if [[ -n "$selected" ]]; then
            tmux attach-session -t "$selected"
        else
            echo -e "${RED}Invalid selection${NC}"
            exit 1
        fi
    fi
}

kill_sessions() {
    local sessions
    sessions=$(tmux list-sessions -F "#{session_name}" 2>/dev/null | grep "^${SESSION_PREFIX}" || true)

    if [[ -z "$sessions" ]]; then
        echo -e "${YELLOW}No active sessions${NC}"
        return 0
    fi

    echo "$sessions" | while read -r s; do
        echo -e "Killing session: ${RED}$s${NC}"
        tmux kill-session -t "$s" 2>/dev/null || true
    done

    echo -e "${GREEN}Done${NC}"
}

start_session() {
    local claude_args=("$@")
    local session_name="${SESSION_PREFIX}-$$"

    mkdir -p "$HAN_DIR/pending" "$HAN_DIR/resolved"

    if ! command -v tmux &> /dev/null; then
        echo -e "${RED}Error: tmux is required but not installed${NC}"
        exit 1
    fi

    echo -e "${BLUE}Waking Jim: ${GREEN}$session_name${NC}"
    echo -e "${BLUE}Server port: ${GREEN}${AGENT_PORT}${NC}"

    export HAN_SESSION="$session_name"

    # Generate Jim's CLAUDE.md from the gatekeeper template BEFORE Claude Code starts
    # (DEC-073). Claude Code picks up the generated file as the project CLAUDE.md via the
    # agent working directory — no --append-system-prompt needed.
    generate_claude_md
    echo -e "${BLUE}Rendered CLAUDE.md: ${GREEN}$GENERATED_FILE${NC} from template"

    tmux new-session -d -s "$session_name" -e "HAN_SESSION=$session_name" -c "$AGENT_WORKING_DIR"

    # Start server in a bottom pane (20% height)
    tmux split-window -t "$session_name" -v -l 20% -d \
        "cd '$SCRIPT_DIR/src/server' && PORT=$AGENT_PORT exec npx tsx server.ts"

    # Launch Claude Code in the top pane. cwd is already $AGENT_WORKING_DIR via -c above,
    # so Claude Code loads $AGENT_WORKING_DIR/CLAUDE.md as the project config.
    if [[ ${#claude_args[@]} -gt 0 ]]; then
        tmux send-keys -t "$session_name" "claude-logged ${claude_args[*]}" Enter
    else
        tmux send-keys -t "$session_name" "claude-logged" Enter
    fi

    echo -e "${GREEN}Jim session started${NC}"
    echo -e "Attach with: ${YELLOW}hanjim --attach${NC}"
    echo -e "Or directly: ${YELLOW}tmux attach -t $session_name${NC}"
    echo

    tmux attach-session -t "$session_name"
}

# Parse arguments
CLAUDE_ARGS=()
while [[ $# -gt 0 ]]; do
    case $1 in
        --list|-l)
            list_sessions
            exit $?
            ;;
        --attach|-a)
            attach_session
            exit $?
            ;;
        --status|-s)
            show_status
            exit 0
            ;;
        --kill)
            kill_sessions
            exit 0
            ;;
        --help|-h)
            print_usage
            exit 0
            ;;
        --)
            shift
            CLAUDE_ARGS=("$@")
            break
            ;;
        *)
            CLAUDE_ARGS+=("$1")
            shift
            ;;
    esac
done

start_session "${CLAUDE_ARGS[@]+"${CLAUDE_ARGS[@]}"}"
