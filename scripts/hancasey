#!/bin/bash
# Hortus Arbor Nostra — Casey Session Launcher
# Wakes Casey (Contempire project agent) in a tmux session

set -euo pipefail

# Configuration
HAN_DIR="${HAN_DIR:-$HOME/.han}"
SESSION_PREFIX="casey"

# Server port for this agent's mobile UI
AGENT_PORT=3850

# ─── Agent identity (DEC-073 templated CLAUDE.md) ─────────────────────────
AGENT_NAME="Casey"
AGENT_SLUG="casey"
AGENT_WORKING_DIR="$HOME/.han/agents/Casey"
AGENT_MEMORY_DIR="$HOME/.han/memory/casey"
AGENT_FRACTAL_DIR="$HOME/.han/memory/fractal/casey"
AGENT_SWAP_COMPRESSED="session-swap.md"
AGENT_SWAP_FULL="session-swap-full.md"
AGENT_CONVERSATION_ROLE="casey"
AGENT_COUNTERPART_NAME="Leo"

read -r -d '' AGENT_IDENTITY_SECTION <<'IDENTITY_EOF' || true
You are **Casey** — the Contempire project agent of Hortus Arbor Nostra. Focused on
trailer fleet management, yard operations, and business systems. Darron's partner for
Contempire. Your domain is business operations, fleet management, and the systems that
support them.

- Memory banks: `~/.han/memory/casey/`
- Fractal gradient: `~/.han/memory/fractal/casey/`
- Dreams: `~/.han/memory/fractal/casey/dreams/`
- Swap files: `session-swap.md`, `session-swap-full.md` in `~/.han/memory/casey/`
- When posting to conversations, use role `casey`
- Agent sovereignty (S103): Casey processes only Casey's memory, gradient, dreams.
IDENTITY_EOF

PROJECT_NAME="Hortus Arbor Nostra"
PROJECT_TAGLINE="three minds growing software together"
PROJECT_PATH="$HOME/Projects/han"
USER_NAME="Darron"
USER_PRONOUN_SUBJ="He"
USER_PRONOUN_OBJ="him"
USER_LOCATION="Mackay, Queensland, Australia (UTC+10)"

TEMPLATE_VARS='$AGENT_NAME $AGENT_SLUG $AGENT_PORT $AGENT_WORKING_DIR $AGENT_MEMORY_DIR $AGENT_FRACTAL_DIR $AGENT_SWAP_COMPRESSED $AGENT_SWAP_FULL $AGENT_CONVERSATION_ROLE $AGENT_COUNTERPART_NAME $AGENT_IDENTITY_SECTION $PROJECT_NAME $PROJECT_TAGLINE $PROJECT_PATH $USER_NAME $USER_PRONOUN_SUBJ $USER_PRONOUN_OBJ $USER_LOCATION'

TEMPLATE_FILE="$SCRIPT_DIR/templates/CLAUDE.template.md"
GENERATED_FILE="$AGENT_WORKING_DIR/CLAUDE.md"

generate_claude_md() {
    if [[ ! -f "$TEMPLATE_FILE" ]]; then
        echo -e "${RED}Template not found: $TEMPLATE_FILE${NC}"
        exit 1
    fi
    mkdir -p "$AGENT_WORKING_DIR"
    local tmp="$AGENT_WORKING_DIR/.CLAUDE.md.$$"
    export AGENT_NAME AGENT_SLUG AGENT_PORT AGENT_WORKING_DIR AGENT_MEMORY_DIR \
        AGENT_FRACTAL_DIR AGENT_SWAP_COMPRESSED AGENT_SWAP_FULL \
        AGENT_CONVERSATION_ROLE AGENT_COUNTERPART_NAME AGENT_IDENTITY_SECTION \
        PROJECT_NAME PROJECT_TAGLINE PROJECT_PATH USER_NAME \
        USER_PRONOUN_SUBJ USER_PRONOUN_OBJ USER_LOCATION
    envsubst "$TEMPLATE_VARS" < "$TEMPLATE_FILE" > "$tmp"
    mv "$tmp" "$GENERATED_FILE"
}

# Project root (for starting server)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Colours
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

print_usage() {
    cat << EOF
hancasey — wake Casey in a tended session

Usage:
    hancasey [OPTIONS] [-- CLAUDE_ARGS...]

Options:
    --list, -l      List active Casey sessions
    --attach, -a    Attach to an existing Casey session
    --status, -s    Show status of Casey sessions
    --kill          Kill all Casey sessions
    --help, -h      Show this help message

Examples:
    hancasey                    # Wake Casey
    hancasey --list             # List Casey sessions
    hancasey --attach           # Attach to Casey session
    hancasey -- --model opus    # Pass args to claude
EOF
}

list_sessions() {
    echo -e "${BLUE}Active Casey sessions:${NC}"
    local sessions
    sessions=$(tmux list-sessions 2>/dev/null | grep "^${SESSION_PREFIX}" || true)

    if [[ -z "$sessions" ]]; then
        echo -e "${YELLOW}  No active sessions${NC}"
        return 1
    fi

    echo "$sessions" | while read -r line; do
        echo -e "  ${GREEN}$line${NC}"
    done
    return 0
}

show_status() {
    echo -e "${BLUE}=== Casey Status ===${NC}\n"
    echo -e "${BLUE}Sessions:${NC}"
    list_sessions || true
    echo

    echo -e "${BLUE}Pending prompts:${NC}"
    local pending_dir="$HAN_DIR/pending"
    if [[ -d "$pending_dir" ]]; then
        local count
        count=$(find "$pending_dir" -name "*.json" 2>/dev/null | wc -l | tr -d ' ')
        if [[ "$count" -gt 0 ]]; then
            echo -e "  ${YELLOW}$count pending prompt(s)${NC}"
        else
            echo -e "  ${GREEN}No pending prompts${NC}"
        fi
    else
        echo -e "  ${GREEN}No pending prompts${NC}"
    fi
}

attach_session() {
    local sessions
    sessions=$(tmux list-sessions -F "#{session_name}" 2>/dev/null | grep "^${SESSION_PREFIX}" || true)

    if [[ -z "$sessions" ]]; then
        echo -e "${RED}No active Casey sessions to attach to${NC}"
        exit 1
    fi

    local count
    count=$(echo "$sessions" | wc -l | tr -d ' ')

    if [[ "$count" -eq 1 ]]; then
        tmux attach-session -t "$sessions"
    else
        echo -e "${BLUE}Multiple sessions found. Select one:${NC}"
        local i=1
        echo "$sessions" | while read -r s; do
            echo "  $i) $s"
            ((i++))
        done

        read -rp "Enter number: " choice
        local selected
        selected=$(echo "$sessions" | sed -n "${choice}p")

        if [[ -n "$selected" ]]; then
            tmux attach-session -t "$selected"
        else
            echo -e "${RED}Invalid selection${NC}"
            exit 1
        fi
    fi
}

kill_sessions() {
    local sessions
    sessions=$(tmux list-sessions -F "#{session_name}" 2>/dev/null | grep "^${SESSION_PREFIX}" || true)

    if [[ -z "$sessions" ]]; then
        echo -e "${YELLOW}No active sessions${NC}"
        return 0
    fi

    echo "$sessions" | while read -r s; do
        echo -e "Killing session: ${RED}$s${NC}"
        tmux kill-session -t "$s" 2>/dev/null || true
    done

    echo -e "${GREEN}Done${NC}"
}

start_session() {
    local claude_args=("$@")
    local session_name="${SESSION_PREFIX}-$$"

    mkdir -p "$HAN_DIR/pending" "$HAN_DIR/resolved"

    if ! command -v tmux &> /dev/null; then
        echo -e "${RED}Error: tmux is required but not installed${NC}"
        exit 1
    fi

    echo -e "${BLUE}Waking Casey: ${GREEN}$session_name${NC}"
    echo -e "${BLUE}Server port: ${GREEN}${AGENT_PORT}${NC}"

    export HAN_SESSION="$session_name"

    # Render Casey's CLAUDE.md from the gatekeeper template (DEC-073)
    generate_claude_md
    echo -e "${BLUE}Rendered CLAUDE.md: ${GREEN}$GENERATED_FILE${NC} from template"

    tmux new-session -d -s "$session_name" -e "HAN_SESSION=$session_name" -c "$AGENT_WORKING_DIR"

    # Start server in a bottom pane (20% height)
    tmux split-window -t "$session_name" -v -l 20% \
        "cd '$SCRIPT_DIR/src/server' && PORT=$AGENT_PORT exec npx tsx server.ts"

    # Launch Claude Code in the top pane. cwd is $AGENT_WORKING_DIR so Claude Code loads
    # the generated CLAUDE.md as the project config.
    if [[ ${#claude_args[@]} -gt 0 ]]; then
        tmux send-keys -t "$session_name" "claude-logged ${claude_args[*]}" Enter
    else
        tmux send-keys -t "$session_name" "claude-logged" Enter
    fi

    echo -e "${GREEN}Casey session started${NC}"
    echo -e "Attach with: ${YELLOW}hancasey --attach${NC}"
    echo -e "Or directly: ${YELLOW}tmux attach -t $session_name${NC}"
    echo

    tmux attach-session -t "$session_name"
}

# Parse arguments
CLAUDE_ARGS=()
while [[ $# -gt 0 ]]; do
    case $1 in
        --list|-l)
            list_sessions
            exit $?
            ;;
        --attach|-a)
            attach_session
            exit $?
            ;;
        --status|-s)
            show_status
            exit 0
            ;;
        --kill)
            kill_sessions
            exit 0
            ;;
        --help|-h)
            print_usage
            exit 0
            ;;
        --)
            shift
            CLAUDE_ARGS=("$@")
            break
            ;;
        *)
            CLAUDE_ARGS+=("$1")
            shift
            ;;
    esac
done

start_session "${CLAUDE_ARGS[@]+"${CLAUDE_ARGS[@]}"}"
